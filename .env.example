# Core app
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gen_app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL_DOMAINS=company.com
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# LLM and extraction
OPENROUTER_API_KEY=your-openrouter-api-key
EXTRACTION_MAX_COST_USD=0.08
EXTRACTION_ARTIFACT_FIRST_ENABLED=1
EXTRACTION_ARTIFACT_FIRST_ROLLBACK_ACTIVE=0
EXTRACTION_ARTIFACT_FIRST_ROLLOUT_PERCENT=100

# Rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Runtime and operations
VERCEL_ENV=development
VERCEL_CRON_SECRET=
LOG_LEVEL=debug

# Observability
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Local test and automation
PLAYWRIGHT_AUTH_BYPASS=0